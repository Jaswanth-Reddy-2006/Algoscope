{
  "name": "database",
  "version": "1.0.0",
  "description": "Algoscope Database Management (Prisma & PostgreSQL)",
  "scripts": {
    "studio": "npx prisma studio --schema ./prisma/schema.prisma",
    "generate": "npx prisma generate --schema ./prisma/schema.prisma",
    "push": "npx prisma db push --schema ./prisma/schema.prisma",
    "reset": "npx prisma db push --force-reset --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  }
}
